            </div>
            <!-- NILOSAFAR IMAGE REVIEW -->
            <div class="glass p-8 flex items-center gap-6">
                <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-[#FF4D00] flex-shrink-0">
