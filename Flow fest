<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hoopinkai | Flow Fest Edition 6</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Plus+Jakarta+Sans:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root { --obsidian: #000000; --ember: #FF4D00; --tan: #D5B893; }
        body { background-color: var(--obsidian); font-family: 'Plus Jakarta Sans', sans-serif; color: white; overflow-x: hidden; }
        .heading { font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
        
        /* LIGHT SPIRAL/FIRE RINGS BACKGROUND */
        .fire-ring {
            position: absolute; border: 1.5px solid var(--ember); border-radius: 50%;
            box-shadow: 0 0 30px var(--ember), inset 0 0 15px var(--ember);
            opacity: 0.15; pointer-events: none;
            animation: drift 25s infinite linear;
        }
        @keyframes drift { from { transform: rotate(0deg) scale(1); } to { transform: rotate(360deg) scale(1.1); } }

        .glass { background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 2rem; }
        .btn-ember { background: var(--ember); box-shadow: 0 0 30px rgba(255, 77, 0, 0.5); transition: 0.3s ease; }
        .btn-ember:hover { transform: scale(1.05); box-shadow: 0 0 50px var(--ember); }
        
        /* Video Container & Hover Play Logic */
        .video-card { position: relative; border-radius: 2rem; overflow: hidden; border: 1px solid var(--ember); background: #111; cursor: pointer; }
        .video-card video { width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.5s; }
        .video-card:hover video { opacity: 1; }
        .video-card .thumbnail { position: absolute; inset: 0; z-index: 5; transition: opacity 0.5s; }
        .video-card:hover .thumbnail { opacity: 0; }

        /* Responsive spacing */
        .section-gap { padding-top: 4rem; padding-bottom: 4rem; }
    </style>
</head>
<body class="antialiased">

    <!-- BACKGROUND LIGHT SPIRALS -->
    <div class="fixed inset-0 z-[-1] pointer-events-none">
        <div class="fire-ring w-[900px] h-[500px] -top-20 -left-40"></div>
        <div class="fire-ring w-[600px] h-[600px] bottom-10 -right-20"></div>
    </div>

    <!-- 1. HERO FOLD: AUTO-PLAY BACKGROUND VIDEO -->
    <header class="relative h-screen w-full flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-black/60 z-10"></div>
            <!-- Background Highlight Video -->
            <video autoplay muted loop playsinline class="w-full h-full object-cover">
                <source src="https://drive.google.com/file/d/17mntqLrpwynyxlf-yifI63OAkJHMVQkk/preview" type="video/mp4">
            </video>
        </div>
        <div class="relative z-20 text-center px-6">
            <!-- NEW FLOW FEST LOGO -->
            <img src="https://github.com/Mindlabzz/Hoopinkai/blob/main/Flow%20Fest%20Logo.png" alt="Flow Fest Logo" class="w-48 md:w-64 mx-auto mb-8 drop-shadow-2xl">
            <h1 class="heading text-5xl md:text-[8rem] mb-2 text-white">Flow Fest <span class="text-[#FF4D00]">6</span></h1>
            <p class="text-lg md:text-xl tracking-[0.4em] text-tan/70 mb-10 uppercase font-light">~ Discover Your Creative Spirit ~</p>
            <a href="#register" class="btn-ember px-14 py-5 rounded-full text-white font-bold tracking-widest text-sm uppercase">Register Now</a>
        </div>
    </header>

    <!-- 2. THE STORY & ABOUT VIDEO -->
    <section class="section-gap px-6 lg:px-24">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
                <h2 class="heading text-4xl md:text-5xl text-[#FF4D00]">The Story</h2>
                <p class="text-lg text-tan font-light leading-relaxed">
                    What does it look like if we let curiosity drive us towards discovering our spirit and capacity? Journey with us through the concept of flow & community. 
                </p>
                <div class="p-6 glass border-l-4 border-[#FF4D00]"><p class="italic text-white">"Prioritising expression & creation over consumption."</p></div>
            </div>
            <!-- HOVER TO PLAY VIDEO -->
            <div class="video-card aspect-video shadow-2xl" onmouseover="this.querySelector('video').play()" onmouseout="this.querySelector('video').pause(); this.querySelector('video').currentTime = 0;">
                <img src="https://images.unsplash.com/photo-1545127398-14699f92334b?auto=format&fit=crop&q=80" class="thumbnail object-cover" alt="Video 1 Thumbnail">
                <video muted loop playsinline><source src="https://drive.google.com/file/d/113rooUa6xxGSlshWTK3H0z7MfmAEb8sE/preview" type="video/mp4"></video>
            </div>
        </div>
    </section>

