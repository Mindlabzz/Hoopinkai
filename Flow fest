    <!-- 7. BRAND PARTNERS -->
    <section class="section-gap border-t border-white/5 opacity-40">
        <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
            <span class="font-black text-xs">PARTNER 1</span> <span class="font-black text-xs">PARTNER 2</span>
