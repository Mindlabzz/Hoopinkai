                            <li>• Sensation Anchoring</li>
                        </ul>
                    </div>
                </div>
                <div class="glass p-8 bg-[#FF4D00]/5 border-[#FF4D00]/20 lg:mt-8">
                    <div>
                        <span class="text-[#FF4D00] font-bold text-[10px] uppercase mb-4 block">Day 04</span>
                        <h4 class="heading text-lg mb-4">Integration</h4>
                        <ul class="text-xs space-y-3 text-tan/60 font-light">
                            <li>• Integration Session</li>
                            <li>• Closing Ceremony</li>
                            <li>• Farm Farewell Lunch</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. TESTIMONIALS (MEGHANA VIDEO + NILO IMAGE) -->
    <section class="section-gap px-6 lg:px-24 bg-white/5">
        <h2 class="heading text-center text-3xl mb-12 text-[#FF4D00]">The Vibe</h2>
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10 items-center">
            <!-- MEGHANA VIDEO (Hover Play) -->
            <div class="video-card aspect-video" onmouseover="this.querySelector('video').play()" onmouseout="this.querySelector('video').pause()">
                <img src="https://images.unsplash.com/photo-1517230878791-4d28214057c2?auto=format&fit=crop&q=80" class="thumbnail object-cover" alt="Meghana Thumbnail">
