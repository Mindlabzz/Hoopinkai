                <p class="text-tan/60 font-light italic">100-Acre farm, lake views, village farm meals. 2h from Bangalore.</p>
                <div class="glass h-72 overflow-hidden border-[#FF4D00]/20">
                    <iframe class="w-full h-full grayscale invert opacity-40" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3888!2d77.5!3d12.9!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTLCsDU0JzAwLjAiTiA3N8KwMzAnMDAuMCJF!5e0!3m2!1sen!2sin!4v1"></iframe>
                </div>
            </div>
            <!-- FULL REGISTRATION FORM -->
            <div id="register" class="glass p-12 border-[#FF4D00]/30 shadow-2xl">
                <h2 class="heading text-3xl mb-8 text-center">Register</h2>
                <form class="space-y-6">
                    <input type="text" placeholder="Full Name" class="w-full bg-transparent border-b border-tan/20 py-4 outline-none focus:border-[#FF4D00] transition">
                    <input type="email" placeholder="Email Address" class="w-full bg-transparent border-b border-tan/20 py-4 outline-none focus:border-[#FF4D00] transition">
                    <select class="w-full bg-black border-b border-tan/20 py-4 outline-none focus:border-[#FF4D00] transition text-tan">
