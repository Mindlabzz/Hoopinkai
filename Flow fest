                </div>
                <h4 class="font-bold tracking-widest uppercase">Yami</h4>
                <p class="text-[10px] text-tan/40 uppercase mt-1">Movement Facilitator</p>
            </div>
            <div class="text-center group">
                <div class="w-48 h-48 rounded-full mx-auto mb-6 border-2 border-[#FF4D00] overflow-hidden grayscale hover:grayscale-0 transition">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80" class="w-full h-full object-cover">
                </div>
                <h4 class="font-bold tracking-widest uppercase">Anch</h4>
                <p class="text-[10px] text-tan/40 uppercase mt-1">Flow Specialist</p>
            </div>
            <div class="text-center group">
                <div class="w-48 h-48 rounded-full mx-auto mb-6 border-2 border-[#FF4D00] overflow-hidden grayscale hover:grayscale-0 transition">
                    <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&q=80" class="w-full h-full object-cover">
                </div>
                <h4 class="font-bold tracking-widest uppercase">Supriya</h4>
                <p class="text-[10px] text-tan/40 uppercase mt-1">Creative Expression</p>
            </div>
            <div class="text-center group">
