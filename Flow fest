                <p class="text-[10px] text-tan/40 uppercase mt-1">Flow Tech Lead</p>
            </div>
        </div>
    </section>

    <!-- 4. THE JOURNEY (SCHEDULE) - VERTICAL LISTS -->
    <section class="section-gap px-6">
